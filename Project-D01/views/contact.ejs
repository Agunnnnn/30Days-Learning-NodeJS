<script src="https://cdn.tailwindcss.com"></script>
<div class="w-full px-0 mt-5 mb-5 py-5">
    <div class="w-full grid grid-cols-12">
        <div class="col-span-12">
            <!-- TOMBOL TAMBAH ADATA -->
            <a href="/contact/add" class="bg-[#0f0e32] rounded-xl px-5 py-2 text-white inline-flex  items-center gap-2   mb-10 ml-5">
                <svg className="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 5v14m-8-7h2m0 0h2m-2 0v2m0-2v-2m12 1h-6m6 4h-6M4 19h16c.5523 0 1-.4477 1-1V6c0-.55228-.4477-1-1-1H4c-.55228 0-1 .44772-1 1v12c0 .5523.44772 1 1 1Z"/>
                </svg>Tambah Data
            </a>    
            <!-- flash msg -->
            <% if (msg.length !== 0) { %>
                <div class="p-4 mb-4 text-sm text-green-strong rounded-base bg-green-100" role="alert">
                    <span class="font-medium">Success alert!</span> <%= msg %>
                </div>
            <% } %>
            <!-- TABEL -->
            <div class="relative overflow-x-auto bg-white shadow-xs rounded-base border border-default">
                <h2 class="font-bold text-center px-2 py-3  bg-[#0f0e32] text-white">DAFTAR KONTAK</h2>
                <table class="w-full mx-auto text-sm text-left rtl:text-right text-body">
                    <thead class="text-sm text-body bg-[#0f0e32] text-white border-b border-white text-center">
                        <tr>
                            <th class="px-10 py-3 font-medium">NO</th>
                            <th class="px-10 py-3 font-medium">Nama</th>
                            <th class="px-10 py-3 font-medium">Nomor</th>
                            <th class="px-10 py-3 font-medium">Email</th>
                            <th class="px-10 py-3 font-medium text-center">INFO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.length === 0) { %>
                        <div class="flex items-start p-4 mb-4 text-sm text-red-800 bg-red-100 rounded-lg" role="alert">
                            <svg class="w-4 h-4 me-2 shrink-0 mt-0.5 sm:mt-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <p><span class="font-medium me-1">Danger alert!</span> Kontak masih kosong</p>
                        </div>
                        <% } %>
                        <% data.forEach((isi_data,i) => { i++ %>
                        <tr class="border-b hover:bg-neutral-secondary-medium text-center">
                            <th class="px-6 py-4 font-medium whitespace-nowrap">
                                <%=  i++  %>
                            </th>
                            <td class="px-10 py-4"><%= isi_data.nama  %></td>
                            <td class="px-10 py-4"><%= isi_data.nohp %></td>
                            <td class="px-10 py-4"><%= isi_data.email %></td>
                            <td class="px-10 py-4 text-center">
                                <a href="/contact/<%= isi_data.nama %>" class="bg-[#0f0e32] rounded-xl px-5 py-2 text-white inline-block">DETAIL</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
        </div>
    </div>
</div>
