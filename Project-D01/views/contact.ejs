<div class="w-full px-5 py-5">
    <div class="grid grid-cols-12">
        <div class="col-span-12">

            <div
                class="relative overflow-x-auto bg-neutral-primary-soft shadow-xs rounded-base border border-default">
                <table
                    class="w-full mx-auto text-sm text-left rtl:text-right text-body"
                >
                    <thead
                        class="text-sm text-body bg-[#0f0e32] text-white border-b border-white text-center"
                    >
                        <h2 class="font-bold text-center bg-[#0f0e32] text-white ">DAFTAR KONTAK</h2>
                        <tr>
                            <th class="px-10 py-3 font-medium">NO</th>
                            <th class="px-10 py-3 font-medium">Nama</th>
                            <th class="px-10 py-3 font-medium">Nomor</th>
                            <th class="px-10 py-3 font-medium">Email</th>
                            <th class="px-10 py-3 font-medium text-center">
                                INFO
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.length === 0) { %>
                                <div class="flex items-start p-4 mb-4 text-sm text-red-800 bg-red-100 rounded-lg" role="alert">
                                    <svg class="w-4 h-4 me-2 shrink-0 mt-0.5 sm:mt-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                                    <p><span class="font-medium me-1">Danger alert!</span> Kontak masih kosong</p>
                                </div>
                        <% } %>
                        <% data.forEach((isi_data,i) => { i++ %>
                            <tr class="border-b hover:bg-neutral-secondary-medium text-center">
                            <th class="px-6 py-4 font-medium whitespace-nowrap">
                                <%=  i++  %>
                            </th>
                            <td class="px-10 py-4"><%= isi_data.nama  %></td>
                            <td class="px-10 py-4"><%= isi_data.nohp %></td>
                            <td class="px-10 py-4"><%= isi_data.email %></td>
                            <td class="px-10 py-4 text-center">
                                <a
                                    href="/contact/<%= isi_data.nama %>"
                                    class="bg-[#0f0e32] rounded-xl px-5 py-2 text-white inline-block"
                                    >DETAIL</a
                                >
                            </td>
                        </tr>
                        <% }) %>

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
