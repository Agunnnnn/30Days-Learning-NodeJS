<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'My App' %></title>

        <!-- STYLE SIMPLE -->
        <style>
            body {
                font-family: Arial, sans-serif;
                margin: 0;
                background-color: #f5f5f5;
            }

            nav {
                background-color: #333;
                padding: 15px;
            }

            nav a {
                color: white;
                margin-right: 15px;
                text-decoration: none;
                font-weight: bold;
            }

            nav a:hover {
                color: #00ffcc;
            }

            .container {
                padding: 20px;
            }

            footer {
                background-color: #222;
                color: white;
                text-align: center;
                padding: 10px;
                margin-top: 30px;
            }
        </style>
    </head>
    <body>
        <!-- NAVBAR -->
        <%- include('nav') %>
        <!-- NAVBAR END -->

        <!-- ISI HALAMAN -->
        <div class="container"><%- body %></div>

        <!-- FOOTER -->
        <footer>
            <p>© 2026 - Project NodeJS Agun</p>
        </footer>
    </body>
</html>
